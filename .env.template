# Environment Variables Template for Cloud Deployment
# Copy this file and set appropriate values for your environment

# Server Configuration
SERVER_PORT=8080

# Database Configuration (from AWS Secrets Manager or environment)
DATABASE_URL=jdbc:postgresql://your-rds-endpoint:5432/resortsdb
DATABASE_USERNAME=dbuser
DATABASE_PASSWORD=secure-password-from-secrets-manager

# Database Connection Pool Settings
DB_POOL_SIZE=10
DB_POOL_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# AWS Configuration
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=resorts-lite-reports
AWS_DB_SECRET_NAME=resorts-lite/db-credentials

# Redis Configuration (Amazon ElastiCache)
REDIS_HOST=your-elasticache-endpoint.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_SSL=true
REDIS_TIMEOUT=2000

# Cache Configuration
CACHE_TTL=3600000

# External Service Endpoints
PAYMENT_SERVICE_URL=http://payment-svc:9090/charge
INVENTORY_SERVICE_URL=http://inventory-svc:8081/rooms
NOTIFICATION_SERVICE_URL=http://notify-svc:7070/send

# H2 Console (disable in production)
H2_CONSOLE_ENABLED=false
