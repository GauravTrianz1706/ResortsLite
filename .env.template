# Environment Variables Template for AWS Deployment
# Copy this file and set appropriate values for your environment

# Server Configuration
SERVER_PORT=8080

# Database Configuration (use AWS RDS endpoint)
DB_URL=jdbc:postgresql://resort-db.cluster-xxxxx.us-east-1.rds.amazonaws.com:5432/resortdb
DB_USERNAME=resort_app_user
DB_PASSWORD=<retrieve-from-secrets-manager>

# AWS Configuration
AWS_REGION=us-east-1

# S3 Bucket Configuration
S3_BUCKET_REPORTS=resort-reports-prod-bucket

# AWS Secrets Manager
DB_SECRET_NAME=prod/resort/db-credentials

# Redis/ElastiCache Configuration
REDIS_HOST=resort-cache.xxxxx.0001.use1.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=<retrieve-from-secrets-manager>
REDIS_TIMEOUT=2000

# Cache Configuration
CACHE_TTL_MINUTES=30

# External Service Endpoints (use AWS service discovery or ALB endpoints)
PAYMENT_ENDPOINT=http://payment-service.internal:9090/payments/charge
INVENTORY_ENDPOINT=http://inventory-service.internal:8081/rooms/available
NOTIFICATION_ENDPOINT=http://notification-service.internal:7070/send

# H2 Console (disable in production)
H2_CONSOLE_ENABLED=false
